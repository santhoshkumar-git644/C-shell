+#!/bin/bash
+cd /home/samadhi-santhosh/Downloads/C-shell/C-shell/mini-project1/xv6-riscv
+
+# 1. getreadcount syscall
+sed -i '/sys_read(void)/a extern uint64 readcount;\nstruct spinlock readcount_lock;' kernel/sysfile.c
+sed -i 's/return fileread(f, p, n);/int ret = fileread(f, p, n);\n  acquire(\&readcount_lock);\n  readcount += ret;\n  release(\&readcount_lock);\n  return ret;/g' kernel/sysfile.c
+
+# Add the getreadcount syscall function in sysproc.c
+cat << 'EOF2' >> kernel/sysproc.c
+
+extern uint64 readcount;
+extern struct spinlock readcount_lock;
+
+uint64 sys_getreadcount(void) {
+  uint64 ret;
+  acquire(&readcount_lock);
+  ret = readcount;
+  release(&readcount_lock);
+  return ret;
+}
+EOF2
+
+# Add to syscall.h
+echo "#define SYS_getreadcount 22" >> kernel/syscall.h
+
+# Add to syscall.c
+sed -i '/\[SYS_mkdir\]  sys_mkdir,/a [SYS_getreadcount] sys_getreadcount,' kernel/syscall.c
+sed -i '/extern uint64 sys_write(void);/a extern uint64 sys_getreadcount(void);' kernel/syscall.c
+
+# Add to user/user.h
+sed -i '/int sleep(int);/a int getreadcount(void);' user/user.h
+
+# Add to user/usys.pl
+sed -i '/entry("sleep");/a entry("getreadcount");' user/usys.pl
+
+# Create user/readcount.c
+cat << 'EOF2' > user/readcount.c
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/fcntl.h"
+
+int main() {
+    int initial = getreadcount();
+    printf("Initial readcount: %d\n", initial);
+    
+    int fd = open("README", O_RDONLY);
+    char buf[100];
+    read(fd, buf, 100);
+    close(fd);
+    
+    int final = getreadcount();
+    printf("Final readcount: %d\n", final);
+    exit(0);
+}
+EOF2
+
+# Add readcount to Makefile
+sed -i '/\$U\/_zombie\\/a \t$U/_readcount\\' Makefile
+
+# 2. Schedulers
+# In Makefile, add SCHEDULER flag
+sed -i 's/CFLAGS = -Wall -Werror -O -fno-omit-frame-pointer -ggdb -gdwarf-2/CFLAGS = -Wall -Werror -O -fno-omit-frame-pointer -ggdb -gdwarf-2 -DSCHEDULER_$(SCHEDULER)/' Makefile
+
+# In kernel/proc.h, add fields to struct proc
+sed -i '/char name\[16\];/a \ \ uint ctime;\n  int nice;\n  uint64 vruntime;\n  int queue;\n  int ticks_used;' kernel/proc.h
+
