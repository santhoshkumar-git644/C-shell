+import sys
+
+def patch_proc_c():
+    with open("kernel/proc.c", "r") as f:
+        content = f.read()
+
+    # 1. Initialize new fields in allocproc
+    allocproc_target = "  p->context.ra = (uint64)forkret;\n  p->context.sp = p->kstack + PGSIZE;"
+    allocproc_replacement = """  p->context.ra = (uint64)forkret;
+  p->context.sp = p->kstack + PGSIZE;
+
+  // Init custom scheduler fields
+  extern uint ticks;
+  p->ctime = ticks;
+  p->nice = 0;
+  p->vruntime = 0;
+  p->queue = 0;
+  p->ticks_used = 0;"""
+    content = content.replace(allocproc_target, allocproc_replacement)
+
+    # 2. Modify scheduler function
+    scheduler_start = """void
+scheduler(void)
+{
+  struct proc *p;
+  struct cpu *c = mycpu();
+
+  c->proc = 0;
+  for(;;){
+    // Avoid deadlock by ensuring that devices can interrupt.
+    intr_on();"""
+
+    scheduler_replacement = """void
+scheduler(void)
+{
+  struct proc *p;
+  struct cpu *c = mycpu();
+  c->proc = 0;
+  for(;;){
+    intr_on();
+    
+#ifdef SCHEDULER_FCFS
+    struct proc *earliest = 0;
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        if(earliest == 0 || p->ctime < earliest->ctime) {
+          if(earliest != 0) release(&earliest->lock);
+          earliest = p;
+        } else {
+          release(&p->lock);
+        }
+      } else {
+        release(&p->lock);
+      }
+    }
+    if(earliest != 0) {
+      earliest->state = RUNNING;
+      c->proc = earliest;
+      swtch(&c->context, &earliest->context);
+      c->proc = 0;
+      release(&earliest->lock);
+    }
+#elif defined(SCHEDULER_CFS)
+    struct proc *best_p = 0;
+    
+    // Print vRuntime log
+    /*
+    printf("[Scheduler Tick]\\n");
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        printf("PID: %d | vRuntime: %d\\n", p->pid, p->vruntime);
+      }
+      release(&p->lock);
+    }
+    */
+    
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        if(best_p == 0 || p->vruntime < best_p->vruntime) {
+          if(best_p != 0) release(&best_p->lock);
+          best_p = p;
+        } else {
+          release(&p->lock);
+        }
+      } else {
+        release(&p->lock);
+      }
+    }
+    
+    if(best_p != 0) {
+      // printf("--> Scheduling PID %d (lowest vRuntime)\\n", best_p->pid);
+      best_p->state = RUNNING;
+      c->proc = best_p;
+      swtch(&c->context, &best_p->context);
+      c->proc = 0;
+      release(&best_p->lock);
+    }
+#elif defined(SCHEDULER_MLFQ)
+    struct proc *best_p = 0;
+    for (int q = 0; q < 4; q++) {
+        for(p = proc; p < &proc[NPROC]; p++) {
+            acquire(&p->lock);
+            if(p->state == RUNNABLE && p->queue == q) {
+                best_p = p;
+                break;
+            }
+            release(&p->lock);
+        }
+        if (best_p) break;
+    }
+    if(best_p != 0) {
+      best_p->state = RUNNING;
+      c->proc = best_p;
+      swtch(&c->context, &best_p->context);
+      c->proc = 0;
+      release(&best_p->lock);
+    }
+#else
+    // Default RR
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        p->state = RUNNING;
+        c->proc = p;
+        swtch(&c->context, &p->context);
+        c->proc = 0;
+      }
+      release(&p->lock);
+    }
+#endif
+"""
+    
+    # We need to replace the entire inner part of scheduler
+    scheduler_end_target = "    }\n  }\n}"
+    
+    start_idx = content.find(scheduler_start)
+    end_idx = content.find(scheduler_end_target, start_idx) + len(scheduler_end_target)
+    
+    content = content[:start_idx] + scheduler_replacement + "\n  }\n}" + content[end_idx:]
+
+    with open("kernel/proc.c", "w") as f:
+        f.write(content)
+
+def patch_trap_c():
+    with open("kernel/trap.c", "r") as f:
+        content = f.read()
+
+    yield_target = "    yield();"
+    yield_replacement = """#ifdef SCHEDULER_FCFS
+    // FCFS does not yield on timer interrupt
+#elif defined(SCHEDULER_CFS)
+    // CFS time slice logic
+    // We update vruntime and yield if time slice is over
+    yield();
+#elif defined(SCHEDULER_MLFQ)
+    // MLFQ logic
+    struct proc *p = myproc();
+    p->ticks_used++;
+    int max_ticks = (p->queue == 0) ? 1 : (p->queue == 1) ? 4 : (p->queue == 2) ? 8 : 16;
+    if (p->ticks_used >= max_ticks) {
+        p->ticks_used = 0;
+        if (p->queue < 3) p->queue++;
+        yield();
+    }
+#else
+    yield();
+#endif"""
+    
+    content = content.replace("    yield();", yield_replacement)
+
+    with open("kernel/trap.c", "w") as f:
+        f.write(content)
+
+patch_proc_c()
+patch_trap_c()
